# App
APP_NAME=Zoho AI Assistant
DEBUG=false

# SQLite memory (sessions + OAuth tokens + long-term preferences)
MEMORY_DB_PATH=./data/memory.db

# Zoho OAuth — register app at https://api-console.zoho.com/
ZOHO_CLIENT_ID=REMOVED_CLIENT_ID
ZOHO_CLIENT_SECRET=REMOVED_CLIENT_SECRET
ZOHO_REDIRECT_URI=http://localhost:8000/auth/callback
# US: accounts.zoho.com / projectsapi.zoho.com
# India: accounts.zoho.in / projectsapi.zoho.in
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_API_DOMAIN=https://projectsapi.zoho.in
ZOHO_PORTAL_ID=tonyrenold051gmaildotcom

# Set true for local dev without Zoho credentials (mock data, open chat)
ZOHO_USE_MOCK=false

# Where OAuth redirects after login
FRONTEND_URL=http://localhost:3000

# LLM (optional — agents use rule-based routing today)
OPENAI_API_KEY=
